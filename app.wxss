page {
  min-height: 100%;
  background: #f6f8fb;
  color: #20242a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 36rpx 32rpx 48rpx;
  background: #f6f8fb;
}

.page.with-tab {
  padding-bottom: 140rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1d2430;
  line-height: 1.25;
}

.subtitle {
  margin-top: 12rpx;
  color: #7b8492;
  font-size: 28rpx;
  line-height: 1.6;
}

.section-title {
  margin: 36rpx 0 18rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #1d2430;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(74, 159, 232, 0.1);
  border: 1rpx solid rgba(218, 226, 236, 0.8);
}

.soft-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 14rpx 38rpx rgba(31, 45, 61, 0.08);
}

.primary-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 48rpx;
  background: #4a9fe8;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 30rpx rgba(74, 159, 232, 0.26);
}

.ghost-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 48rpx;
  background: #ffffff;
  color: #20242a;
  font-size: 30rpx;
  font-weight: 700;
  border: 1rpx solid #dfe6ef;
}

button::after {
  border: 0;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #eaf5ff;
  color: #3388cf;
  font-size: 24rpx;
}

.muted {
  color: #89919e;
}

.progress-line {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #edf1f6;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #54c7b8, #4a9fe8);
}

.empty {
  padding: 56rpx 24rpx;
  text-align: center;
  color: #89919e;
}

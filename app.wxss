page {
  min-height: 100%;
  background: #fff8ee;
  color: #2f3a4a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 36rpx 32rpx 48rpx;
  background: #fff8ee;
}

.page.with-tab {
  padding-bottom: 140rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #2f3a4a;
  line-height: 1.25;
}

.subtitle {
  margin-top: 12rpx;
  color: #8a95a5;
  font-size: 28rpx;
  line-height: 1.6;
}

.section-title {
  margin: 36rpx 0 18rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #2f3a4a;
}

.card {
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0 10rpx 24rpx rgba(90, 72, 55, 0.07);
  border: 2rpx solid rgba(255, 210, 166, 0.55);
}

.soft-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 36rpx;
  box-shadow: 0 10rpx 24rpx rgba(90, 72, 55, 0.07);
}

.primary-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #7bcbff, #8edfe1);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 22rpx rgba(123, 203, 255, 0.28);
}

.ghost-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 48rpx;
  background: #ffffff;
  color: #2f3a4a;
  font-size: 30rpx;
  font-weight: 700;
  border: 2rpx solid rgba(234, 223, 210, 0.9);
}

button::after {
  border: 0;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 24rpx;
}

.muted {
  color: #8a95a5;
}

.progress-line {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f2eadf;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #9de7d7, #7bcbff);
}

.empty {
  padding: 56rpx 24rpx;
  text-align: center;
  color: #8a95a5;
}

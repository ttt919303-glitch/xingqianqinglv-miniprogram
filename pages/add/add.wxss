.type-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin: 34rpx 0 24rpx;
  padding: 8rpx;
}

.type-item {
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 22rpx;
  color: #7b8492;
  font-weight: 800;
}

.type-item.active {
  background: #e7f3ff;
  color: #3388cf;
}

.form {
  padding: 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  margin-bottom: 14rpx;
  color: #4f5967;
  font-weight: 800;
}

input,
textarea,
.picker-value {
  width: 100%;
  border-radius: 22rpx;
  background: #f6f8fb;
  color: #20242a;
  font-size: 28rpx;
}

input,
.picker-value {
  height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
}

textarea {
  min-height: 180rpx;
  padding: 24rpx;
}

.date-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.spot-preview {
  display: grid;
  gap: 14rpx;
  margin: -8rpx 0 26rpx;
}

.spot-chip {
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #fff9f0;
}

.spot-time {
  color: #4a9fe8;
  font-weight: 900;
}

.spot-name {
  color: #20242a;
  font-weight: 900;
}

.spot-note {
  margin-top: 6rpx;
  color: #7b8492;
  font-size: 24rpx;
}

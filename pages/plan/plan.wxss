.trip-tabs {
  display: flex;
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.trip-tab {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #8a95a5;
  font-weight: 700;
  border: 2rpx solid rgba(234, 223, 210, 0.75);
}

.trip-tab.active {
  background: linear-gradient(135deg, #7bcbff, #9de7d7);
  color: #ffffff;
}

.plan-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0fbff 58%, #fff1df 100%);
}

.date-badge {
  width: 112rpx;
  height: 112rpx;
  line-height: 112rpx;
  text-align: center;
  border-radius: 36rpx;
  background: #fff0c7;
  color: #9a6a19;
  font-weight: 900;
  box-shadow: inset 0 -6rpx 0 rgba(255, 183, 165, 0.22);
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.day-tabs {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0 0;
  overflow-x: auto;
}

.day-tab {
  min-width: 172rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #6f7a89;
  border: 2rpx solid rgba(234, 223, 210, 0.9);
  box-shadow: 0 8rpx 18rpx rgba(90, 72, 55, 0.06);
}

.day-tab.active {
  background: linear-gradient(135deg, #7bcbff, #9de7d7);
  color: #ffffff;
  border-color: transparent;
}

.day-title {
  font-size: 26rpx;
  font-weight: 900;
}

.day-count {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.82;
}

.mini-btn {
  min-width: 112rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #3a8fd9;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(90, 72, 55, 0.08);
}

.traffic {
  margin-top: 24rpx;
  padding: 32rpx;
}

.sticker-card {
  border: 2rpx dashed rgba(255, 183, 165, 0.5);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
}

.section-head .section-title {
  margin: 0;
}

.section-actions {
  display: flex;
  gap: 12rpx;
}

.spot-form {
  margin: 20rpx 0 24rpx;
  padding: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
}

.form-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.field-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.field {
  margin-bottom: 18rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #7b8492;
  font-size: 23rpx;
  font-weight: 800;
}

.field input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: #fff8ee;
  color: #2f3a4a;
  font-size: 25rpx;
}

.spot-form-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 4rpx;
}

.poi-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff8ee;
}

.poi-address {
  color: #6d7785;
  font-size: 23rpx;
}

.poi-btn {
  width: 150rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 23rpx;
  font-weight: 900;
}

.poi-results {
  display: grid;
  gap: 12rpx;
  margin: -4rpx 0 20rpx;
}

.poi-item {
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
}

.poi-name {
  font-weight: 900;
}

.poi-meta {
  margin-top: 6rpx;
  color: #89919e;
  font-size: 22rpx;
}

.compact-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  margin: 0;
  font-size: 26rpx;
}

.section-mini {
  margin-bottom: 20rpx;
  color: #89919e;
  font-size: 26rpx;
}

.traffic-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.traffic-icon {
  width: 84rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 26rpx;
  background: #eef9f5;
  font-size: 42rpx;
}

.traffic-name {
  font-size: 32rpx;
  font-weight: 800;
}

.timeline {
  padding: 16rpx 30rpx 8rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
}

.timeline-summary {
  margin: 12rpx 0 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff4dd;
  color: #8a6419;
  font-size: 24rpx;
  font-weight: 800;
}

.conflict-tip {
  margin-bottom: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #fff1f2;
  color: #b2485d;
  font-size: 23rpx;
}

.spot {
  display: grid;
  grid-template-columns: 132rpx 34rpx 1fr auto;
  min-height: 116rpx;
}

.spot.dragging {
  border-radius: 22rpx;
  background: #eef9f5;
}

.time {
  padding-top: 26rpx;
  color: #3a8fd9;
  font-size: 22rpx;
  font-weight: 800;
}

.line-dot {
  position: relative;
}

.line-dot::before {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: repeating-linear-gradient(180deg, #9de7d7 0 12rpx, transparent 12rpx 22rpx);
}

.line-dot::after {
  content: '';
  position: absolute;
  left: 5rpx;
  top: 32rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #9de7d7;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(90, 72, 55, 0.1);
}

.spot-main {
  padding: 22rpx 0 22rpx 14rpx;
}

.spot-name {
  font-size: 32rpx;
  font-weight: 800;
}

.spot-area {
  display: inline-block;
  margin-left: 10rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 20rpx;
  font-weight: 700;
  vertical-align: middle;
}

.spot-note {
  margin-top: 8rpx;
  color: #7b8492;
  line-height: 1.55;
}

.spot-meta {
  margin-top: 8rpx;
  color: #a07835;
  font-size: 23rpx;
}

.spot-transport {
  display: inline-block;
  margin-top: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fff0c7;
  color: #9a6a19;
  font-size: 22rpx;
  font-weight: 800;
}

.spot-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 22rpx;
}

.sort-btn {
  width: 56rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 24rpx;
  font-weight: 900;
}

.sort-btn[disabled] {
  opacity: 0.35;
}

.text-btn {
  width: 76rpx;
  height: 46rpx;
  line-height: 46rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #f7fbff;
  color: #3388cf;
  font-size: 21rpx;
  font-weight: 900;
}

.text-btn.danger {
  color: #d45b5b;
}

.edit-footer {
  padding: 18rpx 0 24rpx;
}

.route-card {
  margin: 26rpx 0 34rpx;
  padding: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffaf2 100%);
}

.route-title {
  font-size: 34rpx;
  font-weight: 900;
}

.strategy-tabs {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.strategy {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff8ee;
  color: #6f7a89;
  font-size: 24rpx;
  font-weight: 800;
}

.strategy.active {
  background: #e9fbf6;
  color: #2f9b8f;
}

.route-tool {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.route-source {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff8ee;
  color: #6f7a89;
  font-size: 23rpx;
  font-weight: 800;
  white-space: nowrap;
}

.route-source.online {
  background: #e9fbf6;
  color: #2f9b8f;
}

.route-source-text {
  margin-top: 12rpx;
  color: #7b8492;
  font-size: 24rpx;
  line-height: 1.5;
}

.map-btn {
  min-width: 210rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7bcbff, #8edfe1);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.route-error {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #fff6e8;
  color: #a16818;
  font-size: 24rpx;
  line-height: 1.45;
}

.assistant-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #fff8ee;
}

.assistant-title {
  color: #253141;
  font-size: 28rpx;
  font-weight: 900;
}

.assistant-desc {
  margin-top: 6rpx;
  color: #6d7785;
  font-size: 23rpx;
  line-height: 1.45;
}

.assistant-btn {
  width: 118rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #9de7d7;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.assistant-result {
  margin-top: 14rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: #eafaf7;
  color: #1f7f77;
  font-size: 24rpx;
  line-height: 1.5;
}

.map-preview {
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background: #eef9f5;
  border: 6rpx solid #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(90, 72, 55, 0.08);
}

.route-map {
  width: 100%;
  height: 360rpx;
}

.map-caption {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  color: #3f657a;
  font-size: 23rpx;
  font-weight: 800;
}

.map-caption text {
  flex: 1;
  min-width: 0;
  line-height: 1.45;
}

.map-focus-btn {
  width: 148rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #ffffff;
  color: #3a8fd9;
  font-size: 22rpx;
  font-weight: 900;
}

.map-spot-card {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff4dd;
  border: 2rpx solid rgba(255, 210, 166, 0.65);
}

.map-detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.map-spot-action {
  width: 100%;
  height: 68rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7bcbff, #8edfe1);
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 68rpx;
}

.route-text {
  margin-top: 14rpx;
  color: #626b78;
  line-height: 1.65;
}

.route-metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.metric {
  padding: 18rpx 12rpx;
  border-radius: 18rpx;
  background: #fff8ee;
  text-align: center;
}

.metric-num {
  color: #3a8fd9;
  font-size: 27rpx;
  font-weight: 900;
}

.metric-label {
  margin-top: 6rpx;
  color: #89919e;
  font-size: 21rpx;
}

.route-tags {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.route-steps {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 2rpx dashed #eadfd2;
}

.route-step {
  display: grid;
  grid-template-columns: 26rpx 1fr;
  gap: 16rpx;
  padding: 14rpx 0;
}

.route-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #cfd8e3;
}

.route-dot.active {
  background: #9de7d7;
}

.route-step-title {
  font-weight: 900;
}

.route-step-desc {
  margin-top: 6rpx;
  color: #89919e;
  font-size: 24rpx;
  line-height: 1.55;
}

.route-line-meta {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  margin-top: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 22rpx;
  font-weight: 800;
}

.segment-options {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.segment-option {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff8ee;
  color: #6f7a89;
  font-size: 22rpx;
  font-weight: 800;
}

.segment-option.active {
  background: #7bcbff;
  color: #ffffff;
}

.delete-btn {
  margin-top: 20rpx;
  color: #d45b5b;
}

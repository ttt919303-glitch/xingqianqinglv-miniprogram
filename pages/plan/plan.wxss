.trip-tabs {
  display: flex;
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.trip-tab {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #7b8492;
  font-weight: 700;
}

.trip-tab.active {
  background: #4a9fe8;
  color: #ffffff;
}

.plan-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  background: linear-gradient(135deg, #ffffff 0%, #e8f5ff 100%);
}

.date-badge {
  width: 112rpx;
  height: 112rpx;
  line-height: 112rpx;
  text-align: center;
  border-radius: 36rpx;
  background: #fff3d9;
  color: #bf7d1d;
  font-weight: 900;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.day-tabs {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0 0;
  overflow-x: auto;
}

.day-tab {
  min-width: 172rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #687382;
  border: 1rpx solid #dfe8f3;
  box-shadow: 0 8rpx 20rpx rgba(31, 45, 61, 0.06);
}

.day-tab.active {
  background: #4a9fe8;
  color: #ffffff;
  border-color: #4a9fe8;
}

.day-title {
  font-size: 26rpx;
  font-weight: 900;
}

.day-count {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.82;
}

.mini-btn {
  min-width: 112rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #4a9fe8;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(74, 159, 232, 0.13);
}

.traffic {
  margin-top: 24rpx;
  padding: 32rpx;
}

.sticker-card {
  border: 2rpx dashed rgba(74, 159, 232, 0.25);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
}

.section-head .section-title {
  margin: 0;
}

.spot-form {
  margin: 20rpx 0 24rpx;
  padding: 28rpx;
}

.form-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.field-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.field {
  margin-bottom: 18rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #7b8492;
  font-size: 23rpx;
  font-weight: 800;
}

.field input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: #f7fbff;
  color: #20242a;
  font-size: 25rpx;
}

.spot-form-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 4rpx;
}

.poi-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f7fbff;
}

.poi-address {
  color: #6d7785;
  font-size: 23rpx;
}

.poi-btn {
  width: 150rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #e7f3ff;
  color: #2d7fc3;
  font-size: 23rpx;
  font-weight: 900;
}

.poi-results {
  display: grid;
  gap: 12rpx;
  margin: -4rpx 0 20rpx;
}

.poi-item {
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
}

.poi-name {
  font-weight: 900;
}

.poi-meta {
  margin-top: 6rpx;
  color: #89919e;
  font-size: 22rpx;
}

.compact-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  margin: 0;
  font-size: 26rpx;
}

.section-mini {
  margin-bottom: 20rpx;
  color: #89919e;
  font-size: 26rpx;
}

.traffic-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.traffic-icon {
  width: 84rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 26rpx;
  background: #e7f3ff;
  font-size: 42rpx;
}

.traffic-name {
  font-size: 32rpx;
  font-weight: 800;
}

.timeline {
  padding: 16rpx 30rpx 8rpx;
}

.timeline-summary {
  margin: 12rpx 0 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff9f0;
  color: #8a6419;
  font-size: 24rpx;
  font-weight: 800;
}

.conflict-tip {
  margin-bottom: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #fff1f2;
  color: #b2485d;
  font-size: 23rpx;
}

.spot {
  display: grid;
  grid-template-columns: 132rpx 34rpx 1fr auto;
  min-height: 116rpx;
}

.spot.dragging {
  border-radius: 22rpx;
  background: #eef7ff;
}

.time {
  padding-top: 26rpx;
  color: #4a9fe8;
  font-size: 22rpx;
  font-weight: 800;
}

.line-dot {
  position: relative;
}

.line-dot::before {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: #dcebf8;
}

.line-dot::after {
  content: '';
  position: absolute;
  left: 5rpx;
  top: 32rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #54c7b8;
}

.spot-main {
  padding: 22rpx 0 22rpx 14rpx;
}

.spot-name {
  font-size: 32rpx;
  font-weight: 800;
}

.spot-area {
  display: inline-block;
  margin-left: 10rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  background: #eef7ff;
  color: #4a9fe8;
  font-size: 20rpx;
  font-weight: 700;
  vertical-align: middle;
}

.spot-note {
  margin-top: 8rpx;
  color: #7b8492;
  line-height: 1.55;
}

.spot-meta {
  margin-top: 8rpx;
  color: #a07835;
  font-size: 23rpx;
}

.spot-transport {
  display: inline-block;
  margin-top: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e7f7f4;
  color: #269384;
  font-size: 22rpx;
  font-weight: 800;
}

.spot-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 22rpx;
}

.sort-btn {
  width: 56rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  background: #eef7ff;
  color: #3388cf;
  font-size: 24rpx;
  font-weight: 900;
}

.sort-btn[disabled] {
  opacity: 0.35;
}

.text-btn {
  width: 76rpx;
  height: 46rpx;
  line-height: 46rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #f7fbff;
  color: #3388cf;
  font-size: 21rpx;
  font-weight: 900;
}

.text-btn.danger {
  color: #d45b5b;
}

.edit-footer {
  padding: 18rpx 0 24rpx;
}

.route-card {
  margin: 26rpx 0 34rpx;
  padding: 32rpx;
}

.route-title {
  font-size: 34rpx;
  font-weight: 900;
}

.strategy-tabs {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.strategy {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #687382;
  font-size: 24rpx;
  font-weight: 800;
}

.strategy.active {
  background: #e7f3ff;
  color: #3388cf;
}

.route-tool {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.route-source {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #687382;
  font-size: 23rpx;
  font-weight: 800;
  white-space: nowrap;
}

.route-source.online {
  background: #e7f7f4;
  color: #269384;
}

.map-btn {
  min-width: 210rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #4a9fe8;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.route-error {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #fff6e8;
  color: #a16818;
  font-size: 24rpx;
  line-height: 1.45;
}

.assistant-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f6fbff;
}

.assistant-title {
  color: #253141;
  font-size: 28rpx;
  font-weight: 900;
}

.assistant-desc {
  margin-top: 6rpx;
  color: #6d7785;
  font-size: 23rpx;
  line-height: 1.45;
}

.assistant-btn {
  width: 118rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #54c7b8;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.assistant-result {
  margin-top: 14rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: #eafaf7;
  color: #1f7f77;
  font-size: 24rpx;
  line-height: 1.5;
}

.map-preview {
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #eef7ff;
  border: 2rpx solid rgba(74, 159, 232, 0.16);
}

.route-map {
  width: 100%;
  height: 360rpx;
}

.map-caption {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  color: #4a6f95;
  font-size: 23rpx;
  font-weight: 800;
}

.map-caption text {
  flex: 1;
  min-width: 0;
  line-height: 1.45;
}

.map-focus-btn {
  width: 148rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #ffffff;
  color: #2d7fc3;
  font-size: 22rpx;
  font-weight: 900;
}

.map-spot-card {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff9f0;
}

.map-detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.map-spot-action {
  width: 100%;
  height: 68rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: #4a9fe8;
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 68rpx;
}

.route-text {
  margin-top: 14rpx;
  color: #626b78;
  line-height: 1.65;
}

.route-metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.metric {
  padding: 18rpx 12rpx;
  border-radius: 18rpx;
  background: #f7fbff;
  text-align: center;
}

.metric-num {
  color: #2d7fc3;
  font-size: 27rpx;
  font-weight: 900;
}

.metric-label {
  margin-top: 6rpx;
  color: #89919e;
  font-size: 21rpx;
}

.route-tags {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.route-steps {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1f6;
}

.route-step {
  display: grid;
  grid-template-columns: 26rpx 1fr;
  gap: 16rpx;
  padding: 14rpx 0;
}

.route-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #cfd8e3;
}

.route-dot.active {
  background: #54c7b8;
}

.route-step-title {
  font-weight: 900;
}

.route-step-desc {
  margin-top: 6rpx;
  color: #89919e;
  font-size: 24rpx;
  line-height: 1.55;
}

.segment-options {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.segment-option {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #687382;
  font-size: 22rpx;
  font-weight: 800;
}

.segment-option.active {
  background: #4a9fe8;
  color: #ffffff;
}

.delete-btn {
  margin-top: 20rpx;
  color: #d45b5b;
}

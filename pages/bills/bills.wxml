<view class="page with-tab bills-page">
  <view class="title">旅行账单</view>
  <view class="subtitle">先记录单人预算和实际花费，路线交通预算会更清楚</view>

  <view class="trip-tabs">
    <view wx:for="{{trips}}" wx:key="id" class="trip-tab {{selectedTripId === item.id ? 'active' : ''}}" bindtap="chooseTrip" data-id="{{item.id}}">
      {{item.city}}
    </view>
  </view>

  <view class="bill-summary card">
    <view class="summary-item">
      <view class="summary-num">¥{{summary.budgetTotal}}</view>
      <view class="summary-label">总预算</view>
    </view>
    <view class="summary-item">
      <view class="summary-num spent">¥{{summary.actualTotal}}</view>
      <view class="summary-label">已花费</view>
    </view>
    <view class="summary-item">
      <view class="summary-num left">¥{{summary.leftBudget}}</view>
      <view class="summary-label">剩余</view>
    </view>
  </view>

  <view wx:for="{{summary.warnings}}" wx:key="*this" class="warning-card">
    {{item}}
  </view>

  <view class="route-bill-card card">
    <view>
      <view class="route-bill-title">路线交通对比</view>
      <view class="bill-meta">预计 ¥{{summary.routeBudget}} · 实际 ¥{{summary.trafficActual}} · 差额 ¥{{summary.trafficDelta}}</view>
    </view>
    <view>
      <view class="route-bill-title">AA 分账</view>
      <view class="bill-meta">{{summary.aaSummary.participants || 0}} 人 · 人均 ¥{{summary.aaSummary.average}}</view>
    </view>
  </view>

  <view class="form-card card">
    <view class="field">
      <view class="label">账单名称</view>
      <input value="{{title}}" placeholder="例如：高铁票 / 午餐 / 门票" bindinput="onTitleInput" />
    </view>
    <view class="field-row">
      <view class="field">
        <view class="label">金额</view>
        <input type="digit" value="{{amount}}" placeholder="例如：139" bindinput="onAmountInput" />
      </view>
      <view class="field">
        <view class="label">分类</view>
        <picker range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
          <view class="picker-value">{{categories[categoryIndex]}}</view>
        </picker>
      </view>
    </view>
    <view class="field">
      <view class="label">类型</view>
      <picker range="{{types}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker-value">{{types[typeIndex]}}</view>
      </picker>
    </view>
    <view class="field-row">
      <view class="field">
        <view class="label">日期</view>
        <input value="{{date}}" placeholder="例如：8月5日" bindinput="onDateInput" />
      </view>
      <view class="field">
        <view class="label">地点</view>
        <input value="{{placeName}}" placeholder="例如：夫子庙" bindinput="onPlaceInput" />
      </view>
    </view>
    <view class="field-row">
      <view class="field">
        <view class="label">支付方式</view>
        <input value="{{payment}}" placeholder="微信 / 支付宝 / 现金" bindinput="onPaymentInput" />
      </view>
      <view class="field">
        <view class="label">AA 人数</view>
        <input type="number" value="{{participants}}" placeholder="例如：2" bindinput="onParticipantsInput" />
      </view>
    </view>
    <view class="field-row">
      <view class="field">
        <view class="label">付款人</view>
        <input value="{{payer}}" placeholder="例如：我 / 小李" bindinput="onPayerInput" />
      </view>
      <view class="field">
        <view class="label">备注</view>
        <input value="{{note}}" placeholder="例如：两人午餐" bindinput="onNoteInput" />
      </view>
    </view>
    <button class="primary-btn" bindtap="saveBill">{{editingBillId ? '保存修改' : '记录账单'}}</button>
  </view>

  <view class="section-title">分类统计</view>
  <view class="category-card card">
    <view wx:for="{{summary.categories}}" wx:key="name" class="category-row">
      <view>{{item.name}}</view>
      <view class="category-money">预算 ¥{{item.budget}} · 已花 ¥{{item.actual}}</view>
    </view>
  </view>

  <view class="section-title">最近记录</view>
  <view wx:for="{{summary.bills}}" wx:key="id" class="bill-item card">
    <view>
      <view class="bill-title">{{item.title}}</view>
      <view class="subtitle">{{item.category}} · {{item.type === 'budget' ? '预算' : '实际花费'}} · {{item.date || '日期待填'}}</view>
      <view class="bill-meta">{{item.placeName || '地点待填'}} · {{item.payment || '支付方式待填'}}</view>
      <view wx:if="{{item.participants > 1}}" class="bill-meta">AA {{item.participants}} 人 · 人均 ¥{{item.shareAmount}} · {{item.payer || '付款人待填'}}</view>
      <view wx:if="{{item.note}}" class="bill-meta">{{item.note}}</view>
    </view>
    <view class="bill-right">
      <view class="bill-money">¥{{item.amount}}</view>
      <view class="bill-actions">
        <button class="mini-btn" bindtap="editBill" data-id="{{item.id}}">编辑</button>
        <button class="mini-btn danger" bindtap="deleteBill" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>
</view>

.trip-tabs {
  display: flex;
  gap: 16rpx;
  margin: 26rpx 0;
  overflow-x: auto;
}

.trip-tab {
  flex: 0 0 auto;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #8a95a5;
  font-weight: 800;
  border: 2rpx solid rgba(234, 223, 210, 0.75);
}

.trip-tab.active {
  background: linear-gradient(135deg, #7bcbff, #9de7d7);
  color: #ffffff;
}

.bill-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  padding: 26rpx;
  background: #fff4dd;
  border-style: dashed;
}

.warning-card {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: #fff1f2;
  color: #b2485d;
  font-size: 24rpx;
  font-weight: 800;
}

.route-bill-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 24rpx;
  background: #f0fbff;
}

.route-bill-title {
  color: #2f3a4a;
  font-size: 28rpx;
  font-weight: 900;
}

.settlement-card {
  margin-top: 18rpx;
  padding: 24rpx;
  background: #fff8ee;
  border-style: dashed;
}

.settlement-line {
  margin-top: 10rpx;
  color: #8a5a20;
  font-size: 24rpx;
  font-weight: 800;
}

.summary-item {
  text-align: center;
}

.summary-num {
  color: #2f3a4a;
  font-size: 34rpx;
  font-weight: 900;
}

.summary-num.spent {
  color: #ff8d76;
}

.summary-num.left {
  color: #2f9b8f;
}

.summary-label,
.label {
  margin-top: 8rpx;
  color: #8a95a5;
  font-size: 24rpx;
}

.form-card,
.category-card,
.bill-item {
  margin-top: 24rpx;
  padding: 28rpx;
}

.field {
  margin-bottom: 22rpx;
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

input,
.picker-value {
  height: 82rpx;
  line-height: 82rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #fff8ee;
  color: #2f3a4a;
}

.category-row,
.bill-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.category-row {
  padding: 18rpx 0;
  border-bottom: 2rpx dashed #eadfd2;
  font-weight: 800;
}

.category-row:last-child {
  border-bottom: 0;
}

.category-money {
  color: #8a95a5;
  font-size: 24rpx;
}

.bill-title {
  font-weight: 900;
  color: #2f3a4a;
}

.bill-meta {
  margin-top: 6rpx;
  color: #8a95a5;
  font-size: 23rpx;
}

.bill-right {
  min-width: 190rpx;
  text-align: right;
}

.bill-money {
  color: #3a8fd9;
  font-size: 32rpx;
  font-weight: 900;
}

.bill-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
  margin-top: 12rpx;
}

.mini-btn {
  min-width: 74rpx;
  height: 50rpx;
  line-height: 50rpx;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 22rpx;
  font-weight: 900;
}

.mini-btn.danger {
  background: #fff1f2;
  color: #d45b5b;
}

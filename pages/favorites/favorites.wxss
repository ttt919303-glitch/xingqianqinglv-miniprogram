.trip-tabs {
  display: flex;
  gap: 16rpx;
  margin: 26rpx 0;
  overflow-x: auto;
}

.trip-tab {
  flex: 0 0 auto;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #8a95a5;
  font-weight: 800;
  border: 2rpx solid rgba(234, 223, 210, 0.75);
}

.trip-tab.active {
  background: linear-gradient(135deg, #7bcbff, #9de7d7);
  color: #ffffff;
}

.day-tabs {
  display: flex;
  gap: 14rpx;
  margin: -10rpx 0 24rpx;
  overflow-x: auto;
}

.day-tab {
  flex: 0 0 auto;
  min-width: 154rpx;
  padding: 16rpx 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
  color: #6f7a89;
  border: 2rpx solid rgba(234, 223, 210, 0.9);
  font-weight: 900;
}

.day-tab text {
  display: block;
  margin-top: 6rpx;
  font-size: 21rpx;
  opacity: 0.78;
}

.day-tab.active {
  background: #eef9f5;
  color: #2f9b8f;
  border-color: rgba(157, 231, 215, 0.75);
}

.filter-tabs {
  display: flex;
  gap: 14rpx;
  margin: 0 0 22rpx;
  overflow-x: auto;
}

.filter-tab {
  flex: 0 0 auto;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #fff8ee;
  color: #6f7a89;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-tab.active {
  background: #9de7d7;
  color: #ffffff;
}

.form-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.form-title {
  margin-bottom: 18rpx;
  color: #2f3a4a;
  font-size: 30rpx;
  font-weight: 900;
}

.field {
  margin-bottom: 18rpx;
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.label {
  margin-bottom: 8rpx;
  color: #8a95a5;
  font-size: 23rpx;
}

input {
  height: 78rpx;
  line-height: 78rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #fff8ee;
  color: #2f3a4a;
  font-size: 25rpx;
}

.poi-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff8ee;
}

.poi-address {
  color: #6d7785;
  font-size: 23rpx;
}

.poi-btn {
  width: 150rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 23rpx;
  font-weight: 900;
}

.poi-results {
  display: grid;
  gap: 12rpx;
  margin: -4rpx 0 20rpx;
}

.poi-item {
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
}

.poi-name {
  font-weight: 900;
}

.poi-meta {
  margin-top: 6rpx;
  color: #89919e;
  font-size: 22rpx;
}

.place-card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 34rpx 28rpx 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff4dd 100%);
  overflow: hidden;
}

.postmark {
  position: absolute;
  right: 24rpx;
  top: 20rpx;
  padding: 8rpx 16rpx;
  border: 2rpx dashed #ffb6b9;
  border-radius: 999rpx;
  color: #c95b6a;
  font-size: 22rpx;
  font-weight: 900;
  transform: rotate(4deg);
}

.place-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding-right: 120rpx;
}

.place-name {
  color: #2f3a4a;
  font-size: 34rpx;
  font-weight: 900;
}

.budget {
  color: #3a8fd9;
  font-size: 32rpx;
  font-weight: 900;
}

.place-note {
  margin-top: 18rpx;
  color: #6f7a89;
  line-height: 1.55;
}

.place-meta {
  display: inline-block;
  margin: 18rpx 0 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 23rpx;
  font-weight: 800;
}

.place-actions {
  display: grid;
  grid-template-columns: 1fr 130rpx 130rpx;
  gap: 14rpx;
}

.ghost-btn.small {
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  padding: 0;
  font-size: 24rpx;
}

.ghost-btn.danger {
  color: #d45b5b;
}

.category-head {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.cat-big-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 34rpx;
  padding: 14rpx;
}

.cat-big-icon image {
  width: 100%;
  height: 100%;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: 34rpx 0 18rpx;
  overflow: hidden;
  border: 1rpx solid #dfe6ef;
  border-radius: 18rpx;
  background: #ffffff;
}

.tab {
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  color: #626b78;
  border-right: 1rpx solid #edf1f6;
}

.tab:last-child {
  border-right: 0;
}

.tab.active {
  background: #e7f3ff;
  color: #3388cf;
  font-weight: 800;
}

.category-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.mini-btn {
  height: 74rpx;
  line-height: 74rpx;
  font-size: 26rpx;
}

.item-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
}

.item-card {
  position: relative;
  min-height: 286rpx;
  padding: 28rpx 26rpx;
  border: 1rpx solid #e5ebf2;
  border-radius: 22rpx;
  background: #ffffff;
}

.item-card.packed {
  border-color: rgba(84, 199, 184, 0.55);
  background: #fbfffe;
}

.item-more {
  position: absolute;
  right: 22rpx;
  top: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.item-icon {
  margin: 42rpx auto 24rpx;
  text-align: center;
  font-size: 82rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 700;
}

.item-count {
  margin-top: 8rpx;
  color: #1d2430;
}

.item-note {
  width: 78%;
  margin-top: 8rpx;
  color: #89919e;
  font-size: 22rpx;
  line-height: 1.45;
}

.check {
  position: absolute;
  right: 26rpx;
  bottom: 28rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border: 3rpx solid #dfe5ec;
  border-radius: 50%;
  color: #ffffff;
  font-weight: 900;
}

.packed .check {
  border-color: #54c7b8;
  background: #54c7b8;
}

.float-add {
  position: fixed;
  right: 46rpx;
  bottom: 72rpx;
  width: 104rpx;
  height: 104rpx;
  line-height: 98rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #1f4f7a;
  font-size: 58rpx;
  box-shadow: 0 18rpx 42rpx rgba(31, 45, 61, 0.16);
}

.category-head {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.cat-big-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 34rpx;
  padding: 14rpx;
}

.cat-big-icon image {
  width: 100%;
  height: 100%;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: 34rpx 0 18rpx;
  overflow: hidden;
  border: 2rpx solid rgba(234, 223, 210, 0.9);
  border-radius: 18rpx;
  background: #ffffff;
}

.tab {
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  color: #6f7a89;
  border-right: 2rpx solid #f2eadf;
}

.tab:last-child {
  border-right: 0;
}

.tab.active {
  background: #e9fbf6;
  color: #2f9b8f;
  font-weight: 800;
}

.category-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.mini-btn {
  height: 74rpx;
  line-height: 74rpx;
  font-size: 26rpx;
}

.item-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
}

.item-card {
  position: relative;
  min-height: 286rpx;
  padding: 28rpx 26rpx;
  border: 2rpx solid rgba(255, 210, 166, 0.6);
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
  box-shadow: 0 10rpx 22rpx rgba(90, 72, 55, 0.06);
}

.item-card.packed {
  border-color: rgba(157, 231, 215, 0.9);
  background: #f2fffb;
}

.item-more {
  position: absolute;
  right: 22rpx;
  top: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.item-icon {
  margin: 42rpx auto 24rpx;
  text-align: center;
  font-size: 82rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f3a4a;
}

.item-count {
  margin-top: 8rpx;
  color: #2f3a4a;
}

.item-note {
  width: 78%;
  margin-top: 8rpx;
  color: #8a95a5;
  font-size: 22rpx;
  line-height: 1.45;
}

.check {
  position: absolute;
  right: 26rpx;
  bottom: 28rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border: 3rpx solid #dfe5ec;
  border-radius: 50%;
  color: #ffffff;
  font-weight: 900;
}

.packed .check {
  border-color: #9de7d7;
  background: #9de7d7;
}

.float-add {
  position: fixed;
  right: 46rpx;
  bottom: 72rpx;
  width: 104rpx;
  height: 104rpx;
  line-height: 98rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7bcbff, #8edfe1);
  color: #ffffff;
  font-size: 58rpx;
  box-shadow: 0 18rpx 42rpx rgba(123, 203, 255, 0.28);
}

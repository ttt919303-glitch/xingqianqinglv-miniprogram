.home-page {
  padding: 0 0 150rpx;
}

.sky {
  position: relative;
  min-height: 1000rpx;
  padding: 96rpx 0 44rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #bfe1ff 0%, #eef8ff 68%, #f6f8fb 100%);
}

.hero {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 72rpx 36rpx;
}

.hero-badge {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.75);
  color: #3388cf;
  font-weight: 800;
  box-shadow: 0 12rpx 28rpx rgba(74, 159, 232, 0.18);
}

.plane {
  position: absolute;
  top: 176rpx;
  left: 420rpx;
  width: 74rpx;
  height: 28rpx;
  border-radius: 50% 80% 50% 80%;
  background: rgba(255, 255, 255, 0.9);
  transform: rotate(-12deg);
}

.plane::before {
  content: '';
  position: absolute;
  left: 24rpx;
  top: -18rpx;
  width: 30rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(74, 159, 232, 0.45);
}

.balloon {
  position: absolute;
  top: 205rpx;
  right: 112rpx;
  width: 58rpx;
  height: 74rpx;
  border-radius: 50% 50% 46% 46%;
  background: linear-gradient(90deg, #f4978e 0 34%, #ffd2a6 34% 66%, #f4978e 66%);
  opacity: 0.78;
}

.balloon::after {
  content: '';
  position: absolute;
  left: 25rpx;
  bottom: -42rpx;
  width: 2rpx;
  height: 44rpx;
  background: rgba(90, 71, 60, 0.45);
}

.cloud {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
}

.cloud::before,
.cloud::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.86);
}

.cloud-a {
  width: 170rpx;
  height: 58rpx;
  right: -18rpx;
  top: 360rpx;
}

.cloud-a::before {
  width: 82rpx;
  height: 82rpx;
  left: 22rpx;
  top: -42rpx;
}

.cloud-a::after {
  width: 104rpx;
  height: 104rpx;
  right: 14rpx;
  top: -64rpx;
}

.cloud-b {
  width: 140rpx;
  height: 46rpx;
  left: 30rpx;
  top: 510rpx;
}

.cloud-b::before {
  width: 70rpx;
  height: 70rpx;
  left: 18rpx;
  top: -36rpx;
}

.cloud-b::after {
  width: 82rpx;
  height: 82rpx;
  right: 16rpx;
  top: -45rpx;
}

.leaf {
  position: absolute;
  width: 34rpx;
  height: 68rpx;
  border-radius: 34rpx 34rpx 4rpx 34rpx;
  background: rgba(113, 191, 137, 0.45);
}

.leaf-a {
  top: 38rpx;
  left: 18rpx;
  transform: rotate(-28deg);
}

.leaf-b {
  right: 18rpx;
  top: 400rpx;
  transform: rotate(42deg);
}

.trip-swiper {
  height: 690rpx;
}

.trip-card {
  position: relative;
  height: 660rpx;
  margin: 0 16rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 42rpx;
  background: linear-gradient(180deg, #91caff 0%, #fef3d7 100%);
  box-shadow: 0 18rpx 44rpx rgba(31, 45, 61, 0.12);
}

.trip-card.lake {
  background: linear-gradient(180deg, #a8dcff 0%, #e9f8df 100%);
}

.trip-card.garden {
  background: linear-gradient(180deg, #b8e3ff 0%, #e8f1c8 100%);
}

.trip-top {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  padding: 48rpx 54rpx 0;
}

.trip-city {
  font-size: 46rpx;
  font-weight: 900;
}

.trip-date {
  margin-top: 18rpx;
  color: #687382;
  font-size: 28rpx;
}

.more {
  font-size: 34rpx;
  font-weight: 800;
}

.scene {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 148rpx;
  height: 330rpx;
}

.sun {
  position: absolute;
  right: 86rpx;
  top: 16rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 221, 142, 0.72);
}

.building {
  position: absolute;
  bottom: 28rpx;
  width: 84rpx;
  background: rgba(112, 152, 184, 0.54);
}

.building-a {
  left: 130rpx;
  height: 170rpx;
}

.building-b {
  left: 226rpx;
  height: 236rpx;
}

.building-c {
  left: 336rpx;
  height: 142rpx;
}

.water {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 86rpx;
  background: rgba(148, 210, 235, 0.52);
}

.status-card {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 190rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(31, 45, 61, 0.1);
}

.days,
.ready {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.num {
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1.05;
}

.ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 118rpx;
  height: 118rpx;
  border: 16rpx solid #54c7b8;
  border-left-color: #edf1f6;
  border-radius: 50%;
}

.ring-text {
  font-size: 32rpx;
  font-weight: 800;
}

.dots {
  display: flex;
  justify-content: center;
  gap: 14rpx;
  margin: -24rpx 0 38rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #d7dce3;
}

.dot.active {
  width: 54rpx;
  background: #4a9fe8;
}

.tip-card,
.prepare-card {
  margin: 0 32rpx 28rpx;
  padding: 30rpx;
}

.tip-card {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.tip-illust {
  flex: 0 0 116rpx;
  width: 116rpx;
  height: 92rpx;
  border-radius: 22rpx;
}

.tip-title,
.prepare-title {
  font-size: 30rpx;
  font-weight: 800;
}

.tip-text {
  margin-top: 8rpx;
  color: #626b78;
  line-height: 1.6;
}

.prepare-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.prepare-percent {
  font-size: 42rpx;
  font-weight: 900;
  color: #4a9fe8;
}

.prepare-card .primary-btn {
  margin-top: 30rpx;
}

.home-page .section-title {
  margin-left: 32rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 0 32rpx 28rpx;
}

.quick-card {
  padding: 26rpx;
}

.quick-icon {
  font-size: 42rpx;
  margin-bottom: 14rpx;
}

.quick-title {
  color: #20242a;
  font-size: 30rpx;
  font-weight: 900;
}

.quick-desc {
  margin-top: 8rpx;
  color: #7b8492;
  font-size: 24rpx;
}

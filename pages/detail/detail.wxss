.detail-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  background: linear-gradient(135deg, #fff9f0 0%, #e8f5ff 100%);
}

.hero-sticker {
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #ffd166;
  color: #7a560e;
  font-weight: 900;
  transform: rotate(4deg);
}

.module-grid,
.split-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 26rpx 0;
}

.module-card,
.split-card {
  padding: 26rpx;
}

.module-card {
  position: relative;
}

.module-card::after {
  content: '›';
  position: absolute;
  right: 24rpx;
  top: 28rpx;
  color: #b7c1ce;
  font-size: 34rpx;
  font-weight: 900;
}

.module-name {
  font-size: 28rpx;
  font-weight: 900;
}

.module-desc {
  margin-top: 10rpx;
  color: #7b8492;
  font-size: 24rpx;
}

.ticket-card {
  display: flex;
  gap: 22rpx;
  padding: 30rpx;
  border: 2rpx dashed rgba(255, 209, 102, 0.65);
}

.ticket-icon {
  width: 84rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 26rpx;
  background: #eef7ff;
  font-size: 42rpx;
}

.ticket-code,
.memo-title,
.split-num {
  color: #20242a;
  font-size: 32rpx;
  font-weight: 900;
}

.ticket-time,
.ticket-note {
  margin-top: 8rpx;
  color: #6b7480;
  font-size: 24rpx;
}

.ticket-price {
  margin-top: 8rpx;
  color: #269384;
  font-size: 24rpx;
  font-weight: 900;
}

.ticket-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 28rpx 0;
}

.memo-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  background: #fff9f0;
}

.mini-btn {
  min-width: 112rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #4a9fe8;
  font-size: 24rpx;
  font-weight: 900;
}

.mini-btn.danger {
  color: #d45b5b;
}

.form-card {
  margin: 24rpx 0;
  padding: 28rpx;
}

.form-title {
  margin-bottom: 20rpx;
  color: #20242a;
  font-size: 30rpx;
  font-weight: 900;
}

.field {
  margin-bottom: 18rpx;
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.label {
  margin-bottom: 8rpx;
  color: #7b8492;
  font-size: 23rpx;
}

input {
  height: 78rpx;
  line-height: 78rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #f6f8fb;
  color: #20242a;
  font-size: 25rpx;
}

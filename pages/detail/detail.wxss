.detail-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0fbff 54%, #fff0df 100%);
}

.hero-sticker {
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #ffd978;
  color: #7a560e;
  font-weight: 900;
  transform: rotate(4deg);
  box-shadow: 0 8rpx 18rpx rgba(90, 72, 55, 0.12);
}

.day-tabs {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0 0;
  overflow-x: auto;
}

.day-tab {
  flex: 0 0 auto;
  min-width: 172rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #6f7a89;
  border: 2rpx solid rgba(234, 223, 210, 0.9);
  box-shadow: 0 8rpx 18rpx rgba(90, 72, 55, 0.06);
}

.day-tab.active {
  background: linear-gradient(135deg, #7bcbff, #9de7d7);
  color: #ffffff;
  border-color: transparent;
}

.day-title {
  font-size: 26rpx;
  font-weight: 900;
}

.day-count {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.82;
}

.day-overview {
  margin-top: 22rpx;
  padding: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffaf2 100%);
}

.overview-title {
  color: #2f3a4a;
  font-size: 30rpx;
  font-weight: 900;
}

.overview-route {
  margin-top: 10rpx;
  color: #6f7a89;
  line-height: 1.55;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.overview-grid > view {
  padding: 16rpx 8rpx;
  border-radius: 18rpx;
  background: #fff8ee;
  text-align: center;
}

.overview-num {
  color: #3a8fd9;
  font-size: 27rpx;
  font-weight: 900;
}

.overview-label {
  margin-top: 6rpx;
  color: #89919e;
  font-size: 21rpx;
}

.module-grid,
.split-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 26rpx 0;
}

.module-card,
.split-card {
  padding: 26rpx;
}

.module-card {
  position: relative;
  min-height: 146rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
}

.module-card::after {
  content: '';
  position: absolute;
  right: -18rpx;
  top: 34rpx;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #fff8ee;
  border: 2rpx solid rgba(255, 210, 166, 0.5);
}

.module-card:nth-child(1) {
  border-style: dashed;
  border-color: rgba(123, 203, 255, 0.7);
}

.module-card:nth-child(2) {
  background: #fff4dd;
  transform: rotate(-1deg);
}

.module-card:nth-child(3) {
  border-style: dashed;
  border-color: rgba(255, 183, 165, 0.65);
}

.module-card:nth-child(4) {
  background: #eef9f5;
  transform: rotate(1deg);
}

.module-card:nth-child(5) {
  background: #fff7fa;
}

.module-card:nth-child(6) {
  background: #f0fbff;
}

.module-name {
  font-size: 28rpx;
  font-weight: 900;
  color: #2f3a4a;
}

.module-desc {
  margin-top: 10rpx;
  color: #8a95a5;
  font-size: 24rpx;
}

.ticket-card {
  display: flex;
  gap: 22rpx;
  padding: 30rpx;
  border: 2rpx dashed rgba(255, 183, 165, 0.72);
  background: linear-gradient(90deg, #ffffff 0%, #ffffff 70%, #fff4dd 100%);
}

.ticket-icon {
  width: 84rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 26rpx;
  background: #eef9f5;
  font-size: 42rpx;
}

.ticket-code,
.memo-title,
.split-num {
  color: #2f3a4a;
  font-size: 32rpx;
  font-weight: 900;
}

.ticket-time,
.ticket-note {
  margin-top: 8rpx;
  color: #6f7a89;
  font-size: 24rpx;
}

.ticket-price {
  margin-top: 8rpx;
  color: #2f9b8f;
  font-size: 24rpx;
  font-weight: 900;
}

.ticket-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 28rpx 0;
}

.memo-card {
  padding: 28rpx;
  background: #fff4dd;
  border-style: dashed;
  transform: rotate(-0.4deg);
}

.memo-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.memo-badge {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 22rpx;
  font-weight: 900;
}

.memo-category-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.memo-category {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #8a95a5;
  font-size: 22rpx;
  font-weight: 800;
}

.memo-category.active {
  background: #7bcbff;
  color: #ffffff;
}

.memo-item {
  display: grid;
  grid-template-columns: 56rpx 1fr auto;
  gap: 18rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 24rpx;
}

.memo-item.done {
  opacity: 0.72;
}

.memo-check {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 50%;
  background: #eef9f5;
  color: #2f9b8f;
  text-align: center;
  font-weight: 900;
}

.memo-line {
  color: #2f3a4a;
  font-size: 28rpx;
  font-weight: 900;
}

.memo-link {
  margin-top: 6rpx;
  color: #a07835;
  font-size: 22rpx;
}

.memo-actions {
  display: flex;
  gap: 10rpx;
}

.mini-btn {
  min-width: 112rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #3a8fd9;
  font-size: 24rpx;
  font-weight: 900;
}

.mini-btn.danger {
  color: #d45b5b;
}

.form-card {
  margin: 24rpx 0;
  padding: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
}

.form-title {
  margin-bottom: 20rpx;
  color: #2f3a4a;
  font-size: 30rpx;
  font-weight: 900;
}

.field {
  margin-bottom: 18rpx;
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.label {
  margin-bottom: 8rpx;
  color: #8a95a5;
  font-size: 23rpx;
}

input {
  height: 78rpx;
  line-height: 78rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #fff8ee;
  color: #2f3a4a;
  font-size: 25rpx;
}

.split-card {
  background: linear-gradient(180deg, #ffffff 0%, #fffaf2 100%);
}

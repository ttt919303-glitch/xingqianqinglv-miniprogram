<view class="page with-tab checklist-page">
  <view class="header">
    <view>
      <view class="title">物品清单</view>
      <view class="subtitle">按类别整理，出发前逐项确认</view>
    </view>
    <image class="suitcase" src="/assets/illustrations/hero-mascot.svg" mode="aspectFit"></image>
  </view>

  <view class="summary card">
    <view class="progress-circle">
      <view class="circle-inner">{{progress.percent}}%</view>
    </view>
    <view class="summary-info">
      <view class="summary-title">已准备</view>
      <view class="summary-count">{{progress.packed}}/{{progress.total}}</view>
      <view class="muted">清单越清楚，旅途越轻松</view>
    </view>
  </view>

  <view class="category-list">
    <view wx:for="{{categories}}" wx:key="id" class="category-card qa-category-card card" bindtap="openCategory" data-id="{{item.id}}">
      <view class="cat-icon" style="background: {{item.color}}22;">
        <image src="{{item.art}}" mode="aspectFit"></image>
      </view>
      <view class="cat-main">
        <view class="cat-name">{{item.name}}</view>
        <view class="muted">已准备 {{item.packed}}/{{item.total}}</view>
        <view class="progress-line">
          <view class="progress-fill" style="width: {{item.percent}}%;"></view>
        </view>
      </view>
      <view class="arrow">›</view>
    </view>
  </view>

  <view class="bottom-actions">
    <button class="ghost-btn" bindtap="unpackAll">清空勾选</button>
    <button class="primary-btn" bindtap="packAll">一键打包完成</button>
  </view>
</view>

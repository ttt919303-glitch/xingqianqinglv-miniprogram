.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.suitcase {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffd978, #ffb7a5);
  box-shadow: inset 0 -8rpx 0 rgba(90, 72, 55, 0.08);
}

.summary {
  display: flex;
  align-items: center;
  gap: 42rpx;
  margin-top: 34rpx;
  padding: 36rpx;
}

.progress-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  border: 18rpx solid #7bcbff;
  border-left-color: #f2eadf;
  border-radius: 50%;
}

.circle-inner {
  font-size: 38rpx;
  font-weight: 900;
}

.summary-title {
  font-size: 32rpx;
  color: #8a95a5;
}

.summary-count {
  margin: 8rpx 0;
  font-size: 44rpx;
  font-weight: 900;
}

.library-section {
  margin-top: 30rpx;
}

.library-scroll {
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.library-card {
  flex: 0 0 286rpx;
  padding: 24rpx;
  background: #fff4dd;
  border-style: dashed;
}

.library-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 20rpx;
  background: #ffffff;
  text-align: center;
  font-size: 34rpx;
}

.library-name {
  margin-top: 16rpx;
  color: #2f3a4a;
  font-size: 28rpx;
  font-weight: 900;
}

.library-desc {
  margin-top: 8rpx;
  min-height: 70rpx;
  color: #8a95a5;
  font-size: 22rpx;
  line-height: 1.45;
}

.library-action {
  display: inline-block;
  margin-top: 14rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #eef9f5;
  color: #2f9b8f;
  font-size: 21rpx;
  font-weight: 800;
}

.weather-section {
  margin-top: 28rpx;
}

.weather-list {
  display: grid;
  gap: 14rpx;
  margin-top: 16rpx;
}

.weather-chip {
  display: grid;
  grid-template-columns: 64rpx 1fr;
  gap: 18rpx;
  align-items: center;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid rgba(255, 210, 166, 0.55);
  box-shadow: 0 10rpx 24rpx rgba(90, 72, 55, 0.06);
}

.weather-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 20rpx;
  background: #eef9f5;
  text-align: center;
  font-size: 34rpx;
}

.weather-name {
  color: #2f3a4a;
  font-size: 28rpx;
  font-weight: 900;
}

.weather-desc {
  margin-top: 6rpx;
  color: #8a95a5;
  font-size: 22rpx;
  line-height: 1.45;
}

.category-list {
  margin-top: 28rpx;
}

.category-card {
  display: flex;
  align-items: center;
  min-height: 142rpx;
  margin-bottom: 22rpx;
  padding: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
}

.cat-icon {
  width: 88rpx;
  height: 88rpx;
  margin-right: 28rpx;
  border-radius: 26rpx;
  padding: 10rpx;
}

.cat-icon image {
  width: 100%;
  height: 100%;
}

.cat-main {
  flex: 1;
}

.cat-name {
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #2f3a4a;
}

.category-card .progress-line {
  margin-top: 16rpx;
}

.arrow {
  color: #c7cdd6;
  font-size: 56rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  padding: 22rpx 32rpx 42rpx;
  background: rgba(255, 248, 238, 0.94);
  box-shadow: 0 -12rpx 28rpx rgba(90, 72, 55, 0.08);
}

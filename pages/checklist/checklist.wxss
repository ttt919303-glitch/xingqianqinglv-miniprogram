.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.suitcase {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  background: #fff2d8;
}

.summary {
  display: flex;
  align-items: center;
  gap: 42rpx;
  margin-top: 34rpx;
  padding: 36rpx;
}

.progress-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  border: 18rpx solid #4a9fe8;
  border-left-color: #eef2f6;
  border-radius: 50%;
}

.circle-inner {
  font-size: 38rpx;
  font-weight: 900;
}

.summary-title {
  font-size: 32rpx;
  color: #7b8492;
}

.summary-count {
  margin: 8rpx 0;
  font-size: 44rpx;
  font-weight: 900;
}

.category-list {
  margin-top: 28rpx;
}

.category-card {
  display: flex;
  align-items: center;
  min-height: 142rpx;
  margin-bottom: 22rpx;
  padding: 28rpx;
}

.cat-icon {
  width: 88rpx;
  height: 88rpx;
  margin-right: 28rpx;
  border-radius: 26rpx;
  padding: 10rpx;
}

.cat-icon image {
  width: 100%;
  height: 100%;
}

.cat-main {
  flex: 1;
}

.cat-name {
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.category-card .progress-line {
  margin-top: 16rpx;
}

.arrow {
  color: #c7cdd6;
  font-size: 56rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  padding: 22rpx 32rpx 42rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 -12rpx 28rpx rgba(31, 45, 61, 0.06);
}

{
  "name": "miniprogram-agent-bridge",
  "version": "0.1.0",
  "description": "Agent-oriented bridge for WeChat DevTools: CLI wrapper, runtime bridge, and miniprogram automation runner.",
  "license": "MIT",
  "private": false,
  "type": "commonjs",
  "bin": {
    "wxmp-devtools": "./bin/devtools.js",
    "wxmp-runner": "./bin/runner.js"
  },
  "files": [
